<div class="edit-profile-container">
  <div class="edit-profile-card">
    <h2>Editar Cadastro</h2>

    <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
      <%= f.error_notification %>

      <div class="form-inputs">
        <%= f.input :email, required: true, autofocus: true, label: "E-mail" %>

        <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
          <p>Atualmente aguardando confirmação de: <%= resource.unconfirmed_email %></p>
        <% end %>

        <%= f.input :password,
                    label: "Nova Senha",
                    hint: "deixe em branco se não quiser alterar",
                    required: false,
                    input_html: { autocomplete: "new-password" } %>
        <%= f.input :password_confirmation,
                    label: "Confirmar Nova Senha",
                    required: false,
                    input_html: { autocomplete: "new-password" } %>
        <%= f.input :current_password,
                    label: "Senha Atual",
                    hint: "precisamos da sua senha atual para confirmar as mudanças",
                    required: true,
                    input_html: { autocomplete: "current-password" } %>
      </div>

      <div class="form-actions">
        <%= f.button :submit, "Atualizar Cadastro", class: "btn-update" %>
      </div>
    <% end %>

    <div class="account-actions">
      <div class="danger-zone">
        <h3>Zona de Perigo</h3>
        <p class="danger-text">Excluir sua conta é uma ação permanente e não pode ser desfeita.</p>
        <%= button_to "Excluir Minha Conta", registration_path(resource_name),
            data: { confirm: "Tem certeza? Esta ação não pode ser desfeita!", turbo_confirm: "Tem certeza? Esta ação não pode ser desfeita!" },
            method: :delete,
            class: "btn-delete-account" %>
      </div>

      <div class="back-link">
        <%= link_to "← Voltar", :back, class: "btn-back" %>
      </div>
    </div>
  </div>
</div>

<style>
  .edit-profile-container {
    max-width: 600px;
    margin: 60px auto;
    padding: 20px;
  }

  .edit-profile-card {
    background: white;
    border-radius: 12px;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    padding: 40px;
  }

  .edit-profile-card h2 {
    margin: 0 0 30px;
    font-size: 32px;
    font-weight: 700;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    text-align: center;
  }

  .edit-profile-card .form-inputs {
    margin-bottom: 30px;
  }

  .edit-profile-card .form-inputs p {
    background: #e6fffa;
    border-left: 4px solid #38b2ac;
    padding: 12px 16px;
    border-radius: 6px;
    margin: 15px 0;
    color: #234e52;
    font-size: 14px;
  }

  .edit-profile-card input[type="email"],
  .edit-profile-card input[type="password"] {
    width: 100%;
    padding: 12px 16px;
    font-size: 16px;
    border: 2px solid #e2e8f0;
    border-radius: 8px;
    transition: all 0.3s ease;
  }

  .edit-profile-card input[type="email"]:focus,
  .edit-profile-card input[type="password"]:focus {
    border-color: #667eea;
    box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
    outline: none;
  }

  .edit-profile-card label {
    font-weight: 600;
    color: #2d3748;
    margin-bottom: 8px;
    display: block;
    font-size: 14px;
  }

  .edit-profile-card .hint {
    font-size: 13px;
    color: #718096;
    margin-top: 6px;
    font-style: italic;
  }

  .edit-profile-card .form-group {
    margin-bottom: 24px;
  }

  .btn-update {
    width: 100%;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%) !important;
    color: white !important;
    border: none !important;
    padding: 14px 24px !important;
    font-size: 16px !important;
    font-weight: 600 !important;
    border-radius: 8px !important;
    cursor: pointer !important;
    transition: transform 0.2s ease, box-shadow 0.2s ease !important;
  }

  .btn-update:hover {
    transform: translateY(-2px) !important;
    box-shadow: 0 10px 25px rgba(102, 126, 234, 0.4) !important;
  }

  .account-actions {
    margin-top: 40px;
    padding-top: 30px;
    border-top: 2px solid #e2e8f0;
  }

  .danger-zone {
    background: #fff5f5;
    border: 2px solid #feb2b2;
    border-radius: 12px;
    padding: 24px;
    margin-bottom: 20px;
  }

  .danger-zone h3 {
    margin: 0 0 10px;
    font-size: 18px;
    font-weight: 700;
    color: #c53030;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .danger-zone h3::before {
    content: "";
    font-size: 20px;
  }

  .danger-text {
    color: #742a2a;
    font-size: 14px;
    margin-bottom: 16px;
    line-height: 1.5;
  }

  .btn-delete-account {
    background: linear-gradient(135deg, #f56565 0%, #c53030 100%) !important;
    color: white !important;
    border: none !important;
    padding: 12px 24px !important;
    font-size: 14px !important;
    font-weight: 600 !important;
    border-radius: 8px !important;
    cursor: pointer !important;
    transition: transform 0.2s ease, box-shadow 0.2s ease !important;
    width: 100%;
  }

  .btn-delete-account:hover {
    transform: translateY(-2px) !important;
    box-shadow: 0 8px 20px rgba(245, 101, 101, 0.4) !important;
  }

  .back-link {
    text-align: center;
    margin-top: 20px;
  }

  .btn-back {
    display: inline-block;
    color: #667eea;
    text-decoration: none;
    font-weight: 600;
    font-size: 14px;
    padding: 12px 24px;
    border-radius: 8px;
    transition: all 0.2s ease;
  }

  .btn-back:hover {
    background: linear-gradient(135deg, #667eea15 0%, #764ba215 100%);
    color: #764ba2;
  }

  .error_notification {
    background: #fed7d7;
    border-left: 4px solid #f56565;
    padding: 12px 16px;
    border-radius: 8px;
    margin-bottom: 24px;
    color: #742a2a;
    font-size: 14px;
  }

  @media (max-width: 768px) {
    .edit-profile-container {
      margin: 20px auto;
      padding: 10px;
    }

    .edit-profile-card {
      padding: 24px;
    }

    .edit-profile-card h2 {
      font-size: 24px;
    }

    .danger-zone {
      padding: 16px;
    }
  }
</style>
