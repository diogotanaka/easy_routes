<p>Hello <%= @email %>!</p>

<% if @resource.try(:unconfirmed_email?) %>
  <p> Nós iremos lhe contatar para te notificar que seu email está sendo alterado para <%= @resource.unconfirmed_email %>.</p>
<% else %>
  <p> Nós iremos lhe contatar para te notificar que seu email foi alterado para <%= @resource.email %>.</p>
<% end %>
