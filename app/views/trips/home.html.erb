<div class="home-container">
  <%= render "shared/banner" %>

  <div class="hero-section">
    <div class="hero-content">
      <h1 class="hero-title">Olá</h1>
      <p class="hero-subtitle">Auxilio você a chegar ao seu destino e aproveitar o melhor da região. Faça o seu cadastro e explore o mundo!</p>

      <div class="cta-buttons">
        <%= link_to "Começar Agora", new_user_registration_path, class: "btn btn-primary-large" %>
        <%= link_to "Saber Mais", "#features", class: "btn btn-secondary-large" %>
      </div>
    </div>

    <div class="hero-image">
      <svg class="travel-illustration" viewBox="0 0 600 600" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <!-- Gradientes -->
          <linearGradient id="skyGradient" x1="0%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" style="stop-color:#667eea;stop-opacity:0.1" />
            <stop offset="100%" style="stop-color:#764ba2;stop-opacity:0.05" />
          </linearGradient>

          <linearGradient id="globeGradient" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" style="stop-color:#667eea;stop-opacity:1" />
            <stop offset="50%" style="stop-color:#7c6eb9;stop-opacity:1" />
            <stop offset="100%" style="stop-color:#764ba2;stop-opacity:1" />
          </linearGradient>

          <linearGradient id="planeGradient" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" style="stop-color:#ffffff;stop-opacity:1" />
            <stop offset="100%" style="stop-color:#e6e6fa;stop-opacity:1" />
          </linearGradient>

          <linearGradient id="pathGradient" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" style="stop-color:#667eea;stop-opacity:0.3" />
            <stop offset="50%" style="stop-color:#764ba2;stop-opacity:0.5" />
            <stop offset="100%" style="stop-color:#667eea;stop-opacity:0.3" />
          </linearGradient>

          <!-- Filtros -->
          <filter id="glow">
            <feGaussianBlur stdDeviation="3" result="coloredBlur"/>
            <feMerge>
              <feMergeNode in="coloredBlur"/>
              <feMergeNode in="SourceGraphic"/>
            </feMerge>
          </filter>

          <filter id="shadow">
            <feDropShadow dx="0" dy="4" stdDeviation="4" flood-opacity="0.2"/>
          </filter>
        </defs>

        <!-- Círculos decorativos de fundo -->
        <circle cx="100" cy="100" r="40" fill="#667eea" opacity="0.05"/>
        <circle cx="500" cy="150" r="60" fill="#764ba2" opacity="0.05"/>
        <circle cx="80" cy="500" r="50" fill="#667eea" opacity="0.05"/>
        <circle cx="520" cy="480" r="45" fill="#764ba2" opacity="0.05"/>

        <!-- Continentes estilizados (mapa-múndi abstrato) -->
        <g opacity="0.15" fill="#667eea">
          <!-- América do Sul -->
          <path d="M 180 280 Q 190 250 200 270 L 210 300 Q 205 320 195 315 Q 185 310 180 280 Z"/>
          <!-- América do Norte -->
          <path d="M 150 180 Q 170 160 190 175 L 200 200 Q 195 220 180 215 Q 165 210 150 180 Z"/>
          <!-- Europa -->
          <path d="M 310 170 Q 320 155 335 165 L 340 185 Q 335 200 325 195 Q 315 190 310 170 Z"/>
          <!-- África -->
          <path d="M 320 240 Q 335 220 350 235 L 355 280 Q 350 300 340 295 Q 330 290 320 240 Z"/>
          <!-- Ásia -->
          <path d="M 380 180 Q 410 165 430 185 L 440 220 Q 430 240 415 235 Q 395 225 380 180 Z"/>
          <!-- Oceania -->
          <path d="M 450 320 Q 465 310 475 320 L 478 340 Q 473 355 465 350 Q 457 345 450 320 Z"/>
        </g>

        <!-- Rotas de viagem (linhas curvas pontilhadas) -->
        <g stroke-dasharray="8,6" stroke-width="2.5" stroke="url(#pathGradient)" fill="none" opacity="0.6">
          <path d="M 180 290 Q 250 230 380 220"/>
          <path d="M 200 260 Q 280 200 420 250"/>
          <path d="M 190 240 Q 300 180 460 330"/>
        </g>

        <!-- Pontos de localização (pins) -->
        <g filter="url(#shadow)">
          <!-- Pin 1 - Brasil -->
          <g transform="translate(200, 290)">
            <circle cx="0" cy="-8" r="12" fill="#667eea"/>
            <circle cx="0" cy="-8" r="6" fill="white"/>
            <path d="M -4 0 L 0 8 L 4 0 Z" fill="#667eea"/>
            <text x="0" y="-4" text-anchor="middle" font-size="10" fill="white">🇧🇷</text>
          </g>

          <!-- Pin 2 - Europa -->
          <g transform="translate(330, 190)">
            <circle cx="0" cy="-8" r="12" fill="#764ba2"/>
            <circle cx="0" cy="-8" r="6" fill="white"/>
            <path d="M -4 0 L 0 8 L 4 0 Z" fill="#764ba2"/>
            <text x="0" y="-4" text-anchor="middle" font-size="10" fill="white">🇫🇷</text>
          </g>

          <!-- Pin 3 - Ásia -->
          <g transform="translate(420, 230)">
            <circle cx="0" cy="-8" r="12" fill="#667eea"/>
            <circle cx="0" cy="-8" r="6" fill="white"/>
            <path d="M -4 0 L 0 8 L 4 0 Z" fill="#667eea"/>
            <text x="0" y="-4" text-anchor="middle" font-size="10" fill="white">🇯🇵</text>
          </g>
        </g>

        <!-- Avião principal (mais bonito e detalhado) -->
        <g transform="translate(300, 300) rotate(-25)" filter="url(#shadow)">
          <!-- Sombra do avião -->
          <ellipse cx="0" cy="15" rx="35" ry="8" fill="#000000" opacity="0.1"/>

          <!-- Corpo do avião -->
          <ellipse cx="0" cy="0" rx="40" ry="12" fill="url(#planeGradient)"/>

          <!-- Asas -->
          <path d="M -15 -2 L -50 -25 L -45 -20 L -12 0 Z" fill="#667eea" opacity="0.9"/>
          <path d="M 15 -2 L 50 -25 L 45 -20 L 12 0 Z" fill="#667eea" opacity="0.9"/>

          <!-- Cauda -->
          <path d="M -35 -3 L -50 -15 L -48 -10 L -35 0 Z" fill="#764ba2" opacity="0.8"/>
          <path d="M -35 3 L -50 15 L -48 10 L -35 0 Z" fill="#764ba2" opacity="0.8"/>

          <!-- Janelas -->
          <g fill="#667eea" opacity="0.4">
            <circle cx="10" cy="0" r="2.5"/>
            <circle cx="3" cy="0" r="2.5"/>
            <circle cx="-4" cy="0" r="2.5"/>
            <circle cx="-11" cy="0" r="2.5"/>
            <circle cx="-18" cy="0" r="2.5"/>
          </g>

          <!-- Cockpit -->
          <circle cx="25" cy="0" r="6" fill="#667eea" opacity="0.7"/>

          <!-- Turbinas -->
          <g fill="#764ba2" opacity="0.6">
            <ellipse cx="-20" cy="-20" rx="5" ry="8"/>
            <ellipse cx="-20" cy="20" rx="5" ry="8"/>
          </g>

          <!-- Detalhe de brilho -->
          <path d="M 20 -4 Q 25 -3 28 -2" stroke="white" stroke-width="1.5" fill="none" opacity="0.6"/>
        </g>

        <!-- Nuvens estilizadas -->
        <g fill="white" opacity="0.4">
          <ellipse cx="450" cy="120" rx="40" ry="20"/>
          <ellipse cx="470" cy="115" rx="35" ry="22"/>
          <ellipse cx="425" cy="118" rx="30" ry="18"/>

          <ellipse cx="120" cy="400" rx="35" ry="18"/>
          <ellipse cx="140" cy="395" rx="30" ry="20"/>
          <ellipse cx="95" cy="398" rx="28" ry="16"/>
        </g>

        <!-- Globo central decorativo -->
        <g transform="translate(300, 450)">
          <circle cx="0" cy="0" r="80" fill="url(#globeGradient)" opacity="0.2" filter="url(#glow)"/>
          <circle cx="0" cy="0" r="80" fill="none" stroke="#667eea" stroke-width="2" opacity="0.3" stroke-dasharray="5,5"/>

          <!-- Linhas do globo -->
          <g stroke="#ffffff" stroke-width="1.5" opacity="0.3" fill="none">
            <ellipse cx="0" cy="0" rx="80" ry="30"/>
            <ellipse cx="0" cy="0" rx="80" ry="50"/>
            <line x1="0" y1="-80" x2="0" y2="80"/>
            <line x1="-80" y1="0" x2="80" y2="0"/>
          </g>

          <!-- Ícone de localização no centro -->
          <g transform="scale(0.8)">
            <circle cx="0" cy="0" r="15" fill="white"/>
            <circle cx="0" cy="0" r="12" fill="#764ba2"/>
            <text x="0" y="6" text-anchor="middle" font-size="16" fill="white">📍</text>
          </g>
        </g>

        <!-- Estrelas/pontos brilhantes -->
        <g fill="#667eea" opacity="0.4">
          <circle cx="150" cy="80" r="3"/>
          <circle cx="480" cy="250" r="2.5"/>
          <circle cx="100" cy="300" r="2"/>
          <circle cx="530" cy="400" r="3"/>
          <circle cx="70" cy="200" r="2.5"/>
        </g>

        <!-- Ícones de destinos (pequenos) -->
        <g opacity="0.6" font-size="20">
          <text x="380" y="380">🏖️</text>
          <text x="200" y="150">🏔️</text>
          <text x="480" y="340">🏛️</text>
          <text x="140" y="450">🌴</text>
        </g>

      </svg>
    </div>
  </div>

  <div id="features" class="features-section">
    <h2 class="section-title">Por Que usar a Easy Routes?</h2>

    <div class="features-grid">
      <div class="feature-card">
        <div class="feature-icon">🤖</div>
        <h3>Assistente IA</h3>
        <p>Chat inteligente que aprende suas preferências e sugere os melhores lugares</p>
      </div>

      <div class="feature-card">
        <div class="feature-icon">🗺️</div>
        <h3>Planejamento Completo</h3>
        <p>Restaurantes, pontos turísticos, transportes e muito mais em um só lugar</p>
      </div>

      <div class="feature-card">
        <div class="feature-icon">💬</div>
        <h3>Chat Contínuo</h3>
        <p>Todas as conversas ficam salvas. Volte quando quiser e continue planejando</p>
      </div>

      <div class="feature-card">
        <div class="feature-icon">🌍</div>
        <h3>Explore o Mundo</h3>
        <p>Descubra destinos incríveis com recomendações personalizadas</p>
      </div>
    </div>
  </div>
</div>

<style>
  .home-container {
    min-height: 100vh;
  }

  .hero-section {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1200px;
    margin: 0 auto;
    padding: 80px 20px;
    gap: 60px;
  }

  .hero-content {
    flex: 1;
    max-width: 600px;
  }

  .hero-title {
    font-size: 64px;
    font-weight: 800;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 20px;
    line-height: 1.2;
  }

  .hero-subtitle {
    font-size: 20px;
    color: #4a5568;
    line-height: 1.6;
    margin-bottom: 40px;
  }

  .cta-buttons {
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
  }

  .btn-primary-large {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    padding: 16px 40px;
    font-size: 18px;
    font-weight: 600;
    border-radius: 12px;
    text-decoration: none;
    display: inline-block;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    box-shadow: 0 4px 15px rgba(102, 126, 234, 0.3);
  }

  .btn-primary-large:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 30px rgba(102, 126, 234, 0.5);
  }

  .btn-secondary-large {
    background: white;
    color: #667eea;
    padding: 16px 40px;
    font-size: 18px;
    font-weight: 600;
    border-radius: 12px;
    text-decoration: none;
    display: inline-block;
    border: 2px solid #667eea;
    transition: all 0.2s ease;
  }

  .btn-secondary-large:hover {
    background: #f7fafc;
    transform: translateY(-2px);
  }

  .hero-image {
    flex: 1;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .travel-illustration {
    width: 100%;
    max-width: 650px;
    height: auto;
    filter: drop-shadow(0 10px 30px rgba(102, 126, 234, 0.15));
  }

  .features-section {
    background: linear-gradient(135deg, #667eea 0%, #8e7ba1 100%);
    padding: 80px 20px;
    color: white;
  }

  .section-title {
    text-align: center;
    font-size: 42px;
    font-weight: 700;
    margin-bottom: 60px;
  }

  .features-grid {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 30px;
  }

  .feature-card {
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
    border-radius: 16px;
    padding: 40px 30px;
    text-align: center;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    border: 1px solid rgba(255, 255, 255, 0.2);
  }

  .feature-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.2);
    background: rgba(255, 255, 255, 0.15);
  }

  .feature-icon {
    font-size: 48px;
    margin-bottom: 20px;
  }

  .feature-card h3 {
    font-size: 24px;
    font-weight: 700;
    margin-bottom: 12px;
  }

  .feature-card p {
    font-size: 16px;
    opacity: 0.9;
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    .hero-section {
      flex-direction: column;
      padding: 40px 20px;
      gap: 40px;
    }

    .hero-title {
      font-size: 42px;
    }

    .hero-subtitle {
      font-size: 18px;
    }

    .hero-image {
      order: -1;
    }

    .cta-buttons {
      flex-direction: column;
    }

    .btn-primary-large,
    .btn-secondary-large {
      width: 100%;
      text-align: center;
    }

    .features-grid {
      grid-template-columns: 1fr;
    }

    .section-title {
      font-size: 32px;
    }
  }
</style>
