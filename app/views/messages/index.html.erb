<h1>Chat da viagem</h1>

<div data-controller="hello"></div>

<div id = "messages"
  data-controller="autoscroll"
  data-action="turbo:after-stream-render->autoscroll#scroll"
  style="max-height: 400px; overflow-y: auto;">

  <%= render @messages %>
  
</div>

<%= simple_form_for [@trip, @message] do |f| %>
  <%= f.input :content, label: false, placeholder: "Digite uma mensagem..." %>
  <%= f.submit "Enviar" %>
<% end %>
